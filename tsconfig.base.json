{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@newquantmodel/shared-types": [
        "packages/shared-types/src/index.ts"
      ],
      "@newquantmodel/ui": [
        "packages/ui/src/index.ts"
      ]
    }
  }
}
